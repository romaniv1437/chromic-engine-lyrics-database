[{"time":8.18,"text":"I'm known as the siren of all seven seas","words":[{"word":"I'm","start":8.18,"end":8.929,"whisper":true},{"word":"known","start":8.939,"end":9.276,"spoken":true},{"word":"as","start":9.286,"end":9.586,"spoken":true},{"word":"the","start":9.596,"end":9.879,"spoken":true},{"word":"siren","start":9.889,"end":10.372,"spoken":true},{"word":"of","start":10.382,"end":10.737,"spoken":true},{"word":"all","start":10.747,"end":11.23,"spoken":true},{"word":"seven","start":11.24,"end":11.687,"spoken":true},{"word":"seas","start":11.697,"end":12.71,"spoken":true}],"end":12.71},{"time":12.71,"text":"The breaker of hearts by the bay","words":[{"word":"The","start":12.71,"end":13.112,"sung":true},{"word":"breaker","start":13.122,"end":13.533,"spoken":true},{"word":"of","start":13.543,"end":13.82,"spoken":true},{"word":"hearts","start":13.83,"end":14.337,"spoken":true},{"word":"by","start":14.347,"end":14.644,"spoken":true},{"word":"the","start":14.654,"end":15.474,"spoken":true},{"word":"bay","start":15.639,"end":16.47,"sung":true}],"end":16.47},{"time":16.47,"text":"So if you go swimmin' with bow-legged women","words":[{"word":"So","start":16.47,"end":16.941,"spoken":true},{"word":"if","start":17.054,"end":17.412,"spoken":true},{"word":"you","start":17.422,"end":17.732,"spoken":true},{"word":"go","start":17.742,"end":18.015,"sung":true},{"word":"swimmin'","start":18.025,"end":18.561},{"word":"with","start":18.599,"end":19.013,"sung":true},{"word":"bow-legged","start":19.023,"end":19.371,"spoken":true},{"word":"women","start":19.381,"end":20.4,"spoken":true,"stretch":true}],"end":20.4},{"time":20.4,"text":"I might steal your weak heart away","words":[{"word":"I","start":20.4,"end":21.4,"spoken":true},{"word":"might","start":22.24,"end":23.04,"spoken":true},{"word":"steal","start":23.05,"end":23.84,"spoken":true},{"word":"your","start":23.85,"end":24.48,"sung":true},{"word":"weak","start":24.49,"end":25.12,"spoken":true},{"word":"heart","start":25.13,"end":25.92,"spoken":true},{"word":"away","start":25.93,"end":29.12,"sung":true,"stretch":true}],"end":29.12},{"time":24.2,"text":"","type":"vocal_cue","end":35.45},{"time":35.75,"text":"A big-bottomed sea-witch may bob through the waves","words":[{"word":"A","start":35.75,"end":36.299,"whisper":true},{"word":"big-bottomed","start":36.606,"end":37.22,"sung":true},{"word":"sea-witch","start":37.23,"end":37.769},{"word":"may","start":37.779,"end":38.252},{"word":"bob","start":38.262,"end":38.646},{"word":"through","start":38.656,"end":39.041},{"word":"the","start":39.051,"end":39.393,"spoken":true},{"word":"waves","start":39.403,"end":40.64,"stretch":true}],"end":40.64},{"time":40.64,"text":"And hope to lead sailors astray","words":[{"word":"And","start":40.64,"end":41.04},{"word":"hope","start":41.378,"end":41.588,"spoken":true},{"word":"to","start":41.598,"end":41.841},{"word":"lead","start":41.851,"end":42.263},{"word":"sailors","start":42.273,"end":42.495},{"word":"astray","start":42.505,"end":44.25,"sung":true,"stretch":true}],"end":44.25},{"time":44.25,"text":"But a true ocean goddess must fill out her bodice","words":[{"word":"But","start":44.25,"end":45.09},{"word":"a","start":45.136,"end":45.444,"spoken":true},{"word":"true","start":45.454,"end":45.809,"spoken":true},{"word":"ocean","start":45.819,"end":46.194,"spoken":true},{"word":"goddess","start":46.204,"end":46.637,"spoken":true},{"word":"must","start":46.647,"end":47.176,"spoken":true},{"word":"fill","start":47.186,"end":47.561,"spoken":true},{"word":"out","start":47.571,"end":48.023,"spoken":true},{"word":"her","start":48.033,"end":48.389},{"word":"bodice","start":48.399,"end":50.07,"sung":true,"stretch":true}],"end":50.07},{"time":50.07,"text":"To present an alluring display","words":[{"word":"To","start":50.07,"end":51.34,"sung":true},{"word":"present","start":51.35,"end":52.708,"spoken":true},{"word":"an","start":52.718,"end":53.718},{"word":"alluring","start":53.728,"end":55.51,"spoken":true},{"word":"display","start":55.52,"end":60.07,"whisper":true,"stretch":true}],"end":60.07},{"time":52.87,"text":"","type":"vocal_cue","end":59.77},{"time":60.07,"text":"Oh—! Beware of old oysters too large in the chest","words":[{"word":"Oh—!","start":60.07,"end":60.904,"spoken":true},{"word":"Beware","start":60.946,"end":61.27},{"word":"of","start":61.28,"end":61.479},{"word":"old","start":61.489,"end":61.993,"spoken":true},{"word":"oysters","start":62.003,"end":62.565,"spoken":true},{"word":"too","start":62.575,"end":62.831,"spoken":true},{"word":"large","start":62.841,"end":63.193,"spoken":true},{"word":"in","start":63.203,"end":63.441},{"word":"the","start":63.451,"end":63.745},{"word":"chest","start":63.755,"end":64.45,"spoken":true}],"end":64.45},{"time":64.45,"text":"Let's banish them from the buffet","words":[{"word":"Let's","start":64.45,"end":64.759,"spoken":true},{"word":"banish","start":64.769,"end":65.473,"spoken":true},{"word":"them","start":65.483,"end":65.879},{"word":"from","start":65.889,"end":66.265,"spoken":true},{"word":"the","start":66.275,"end":66.748,"spoken":true},{"word":"buffet","start":66.758,"end":68.37,"sung":true,"stretch":true}],"end":68.37},{"time":68.37,"text":"I'm far more nutritious—","words":[{"word":"I'm","start":68.37,"end":68.685,"spoken":true},{"word":"far","start":68.911,"end":69.088},{"word":"more","start":69.098,"end":69.264},{"word":"nutritious—","start":69.274,"end":70.07,"spoken":true,"stretch":true}],"end":70.07},{"time":70.07,"text":"You smell like the fishes","words":[{"word":"You","start":70.07,"end":70.603,"spoken":true},{"word":"smell","start":70.613,"end":70.947},{"word":"like","start":70.957,"end":71.377},{"word":"the","start":71.387,"end":71.6},{"word":"fishes","start":71.61,"end":72.58,"spoken":true,"stretch":true}],"end":72.58},{"time":72.58,"text":"Did I hear a banshee?","words":[{"word":"Did","start":72.58,"end":72.876,"spoken":true},{"word":"I","start":72.971,"end":73.258},{"word":"hear","start":73.316,"end":73.477,"spoken":true},{"word":"a","start":73.487,"end":73.707},{"word":"banshee?","start":73.717,"end":74.04,"spoken":true}],"end":74.04},{"time":74.04,"text":"You're sea-green with envy!","words":[{"word":"You're","start":74.04,"end":74.385},{"word":"sea-green","start":74.395,"end":74.878},{"word":"with","start":74.888,"end":75.592,"spoken":true},{"word":"envy!","start":75.602,"end":77.23,"spoken":true,"stretch":true}],"end":77.23},{"time":77.23,"text":"This mermaid enchantress—","words":[{"word":"This","start":77.23,"end":77.576,"spoken":true},{"word":"mermaid","start":77.586,"end":78.198,"spoken":true},{"word":"enchantress—","start":78.353,"end":79.58,"spoken":true,"stretch":true}],"end":79.58},{"time":79.58,"text":"No, I, Birth of Venus","words":[{"word":"No,","start":79.58,"end":79.852},{"word":"I,","start":79.862,"end":80.454,"sung":true},{"word":"Birth","start":80.464,"end":80.92},{"word":"of","start":80.93,"end":81.289,"spoken":true},{"word":"Venus","start":81.299,"end":82.96,"sung":true,"stretch":true}],"end":82.96},{"time":82.96,"text":"Will send sailors swimming all day!","words":[{"word":"Will","start":82.96,"end":83.12,"whisper":true},{"word":"send","start":83.13,"end":83.76,"spoken":true},{"word":"sailors","start":83.77,"end":84.72},{"word":"swimming","start":84.73,"end":86.6,"spoken":true},{"word":"all","start":86.76,"end":87.6},{"word":"day!","start":87.61,"end":90.8,"spoken":true,"stretch":true}],"end":90.8}]