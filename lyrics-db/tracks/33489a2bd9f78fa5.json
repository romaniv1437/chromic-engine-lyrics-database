67.51}, {"word": "stenar", "start": 167.52, "end": 167.62}]}, {"time": 167.63, "text": "Inte många fattar vad jag menar", "words": [{"word": "Inte", "start": 167.63, "end": 167.73}, {"word": "många", "start": 167.74, "end": 167.84}, {"word": "fattar", "start": 167.85, "end": 167.95}, {"word": "vad", "start": 167.96, "end": 168.06}, {"word": "jag", "start": 168.07, "end": 168.17}, {"word": "menar", "start": 168.18, "end": 168.28}]}, {"time": 168.29, "text": "Vågorna kom när jag segla", "words": [{"word": "Vågorna", "start": 168.29, "end": 168.39}, {"word": "kom", "start": 168.4, "end": 168.5}, {"word": "när", "start": 168.51, "end": 168.61}, {"word": "jag", "start": 168.62, "end": 168.72}, {"word": "segla", "start": 168.73, "end": 168.83}]}, {"time": 168.84, "text": "Om jag lever imorn, jag har segrat", "words": [{"word": "Om", "start": 168.84, "end": 168.94}, {"word": "jag", "start": 168.95, "end": 169.05}, {"word": "lever", "start": 169.06, "end": 169.16}, {"word": "imorn,", "start": 169.17, "end": 169.27}, {"word": "jag", "start": 169.28, "end": 169.38}, {"word": "har", "start": 169.39, "end": 169.49}, {"word": "segrat", "start": 169.5, "end": 169.6}]}, {"time": 169.61, "text": "Det är crazy", "words": [{"word": "Det", "start": 169.61, "end": 169.71}, {"word": "är", "start": 169.72, "end": 169.82}, {"word": "crazy", "start": 169.83, "end": 169.93}]}, {"time": 169.94, "text": "I was just a lost little baby", "words": [{"word": "I", "start": 169.94, "end": 170.04}, {"word": "was", "start": 170.05, "end": 170.15}, {"word": "just", "start": 170.16, "end": 170.26}, {"word": "a", "start": 170.27, "end": 170.37}, {"word": "lost", "start": 170.38, "end": 170.48}, {"word": "little", "start": 170.49, "end": 170.59}, {"word": "baby", "start": 170.6, "end": 170.7}]}, {"time": 170.71, "text": "I'm waiting for somebody to come save me", "words": [{"word": "I'm", "start": 170.71, "end": 170.81}, {"word": "waiting", "start": 170.82, "end": 170.92}, {"word": "for", "start": 170.93, "end": 171.03}, {"word": "somebody", "start": 171.04, "end": 171.14}, {"word": "to", "start": 171.15, "end": 171.25}, {"word": "come", "start": 171.26, "end": 171.36}, {"word": "save", "start": 171.37, "end": 171.47}, {"word": "me", "start": 171.48, "end": 171.58}]}, {"time": 171.59, "text": "I wanna change the world but never change me", "words": [{"word": "I", "start": 171.59, "end": 171.69}, {"word": "wanna", "start": 171.7, "end": 171.8}, {"word": "change", "start": 171.81, "end": 171.91}, {"word": "the", "start": 171.92, "end": 172.02}, {"word": "world", "start": 172.03, "end": 172.13}, {"word": "but", "start": 172.14, "end": 172.24}, {"word": "never", "start": 172.25, "end": 172.35}, {"word": "change", "start": 172.36, "end": 172.46}, {"word": "me", "start": 172.47, "end": 172.57}]}, {"time": 172.58, "text": "Vill de se mig död, they gotta spray me", "words": [{"word": "Vill", "start": 172.58, "end": 172.68}, {"word": "de", "start": 172.69, "end": 172.79}, {"word": "se", "start": 172.8, "end": 172.9}, {"word": "mig", "start": 172.91, "end": 173.01}, {"word": "död,", "start": 173.02, "end": 173.12}, {"word": "they", "start": 173.13, "end": 173.23}, {"word": "gotta", "start": 173.24, "end": 173.34}, {"word": "spray", "start": 173.35, "end": 173.45}, {"word": "me", "start": 173.46, "end": 173.56}]}, {"time": 173.57, "text": "Få vet vad min bror vet", "words": [{"word": "Få", "start": 173.57, "end": 173.67}, {"word": "vet", "start": 173.68, "end": 173.78}, {"word": "vad", "start": 173.79, "end": 173.89}, {"word": "min", "start": 173.9, "end": 174.0}, {"word": "bror", "start": 174.01, "end": 174.11}, {"word": "vet", "start": 174.12, "end": 174.22}]}, {"time": 174.23, "text": "För myror förstår inte storhet", "words": [{"word": "För", "start": 174.23, "end": 174.33}, {"word": "myror", "start": 174.34, "end": 174.44}, {"word": "förstår", "start": 174.45, "end": 174.55}, {"word": "inte", "start": 174.56, "end": 174.66}, {"word": "storhet", "start": 174.67, "end": 17