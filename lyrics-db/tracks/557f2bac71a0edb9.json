[{"time": 18.2, "text": "Time present and time past", "words": [{"word": "Time", "start": 18.2, "end": 19.48, "stretch": true}, {"word": "present", "start": 19.49, "end": 20.08}, {"word": "and", "start": 20.09, "end": 21.04, "stretch": true}, {"word": "time", "start": 21.05, "end": 21.4}, {"word": "past", "start": 21.41, "end": 22.34}]}, {"time": 22.35, "text": "Are both perhaps present in time future", "words": [{"word": "Are", "start": 22.35, "end": 23.28, "stretch": true}, {"word": "both", "start": 23.29, "end": 23.6}, {"word": "perhaps", "start": 23.61, "end": 24.32}, {"word": "present", "start": 24.33, "end": 25.0}, {"word": "in", "start": 25.01, "end": 25.36}, {"word": "time", "start": 25.37, "end": 25.54}, {"word": "future", "start": 25.55, "end": 27.58, "stretch": true}]}, {"time": 29.62, "text": "And time future contained in time past", "words": [{"word": "And", "start": 29.62, "end": 29.98}, {"word": "time", "start": 29.99, "end": 30.09}, {"word": "future", "start": 30.1, "end": 30.2}, {"word": "contained", "start": 30.21, "end": 30.31}, {"word": "in", "start": 30.32, "end": 30.42}, {"word": "time", "start": 30.43, "end": 30.53}, {"word": "past", "start": 30.54, "end": 30.64}]}, {"type": "vocal_cue", "time": 30.94, "end": 41.24}, {"time": 41.54, "text": "If all time is eternally present", "words": [{"word": "If", "start": 41.54, "end": 41.72}, {"word": "all", "start": 41.73, "end": 42.0}, {"word": "time", "start": 42.01, "end": 42.26}, {"word": "is", "start": 42.27, "end": 42.56}, {"word": "eternally", "start": 42.57, "end": 43.08}, {"word": "present", "start": 43.09, "end": 43.68}]}, {"time": 44.26, "text": "All time is unredeemable", "words": [{"word": "All", "start": 44.26, "end": 44.54}, {"word": "time", "start": 44.55, "end": 44.84}, {"word": "is", "start": 44.85, "end": 45.12}, {"word": "unredeemable", "start": 45.13, "end": 46.24}]}, {"time": 48.26, "text": "What might have been is an abstraction", "words": [{"word": "What", "start": 48.26, "end": 4