": 320.597, "end": 321.371}]}, {"time": 321.381, "text": "Ja, hora, sådan är jag", "words": [{"word": "Ja,", "start": 321.381, "end": 321.664}, {"word": "hora,", "start": 321.674, "end": 322.154}, {"word": "sådan", "start": 322.164, "end": 322.644}, {"word": "är", "start": 322.654, "end": 322.84}, {"word": "jag", "start": 322.85, "end": 323.134}]}, {"time": 323.144, "text": "Låt mig ta tillbaks mitt sikte", "words": [{"word": "Låt", "start": 323.144, "end": 323.428}, {"word": "mig", "start": 323.438, "end": 323.722}, {"word": "ta", "start": 323.732, "end": 323.917}, {"word": "tillbaks", "start": 323.927, "end": 324.701}, {"word": "mitt", "start": 324.711, "end": 325.093}, {"word": "sikte", "start": 325.103, "end": 325.583}]}, {"time": 325.593, "text": "För just nu är jag bländad av sättet du säger mitt namn", "words": [{"word": "För", "start": 325.593, "end": 325.877}, {"word": "just", "start": 325.887, "end": 326.268}, {"word": "nu", "start": 326.278, "end": 326.464}, {"word": "är", "start": 326.474, "end": 326.66}, {"word": "jag", "start": 326.67, "end": 326.954}, {"word": "bländad", "start": 326.964, "end": 327.64}, {"word": "av", "start": 327.65, "end": 327.836}, {"word": "sättet", "start": 327.846, "end": 328.423}, {"word": "du", "start": 328.433, "end": 328.619}, {"word": "säger", "start": 328.629, "end": 329.109}, {"word": "mitt", "start": 329.119, "end": 329.501}, {"word": "namn", "start": 329.511, "end": 329.893}]}, {"time": 329.903, "text": "Jag var förresten kär direkt", "words": [{"word": "Jag", "start": 329.903, "end": 330.187}, {"word": "var", "start": 330.197, "end": 330.481}, {"word": "förresten", "start": 330.491, "end": 331.362}, {"word": "kär", "start": 331.372, "end": 331.656}, {"word": "direkt", "start": 331.666, "end": 332.244}]}, {"time": 332.254, "text": "Redo för \"Jag gör\" och nya dagar, yuh", "words": [{"word": "Redo", "start": 332.254, "end": 332.636}, {"word": "för", "start": 332.646, "end": 332.93}, {"word": "\"Jag", "start": 332.94, "